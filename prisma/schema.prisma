generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  phone         String?        @unique
  password      String?
  image         String?
  hasFullAccess Boolean        @default(false)
  isAdmin       Boolean        @default(false)
  isPremium     Boolean        @default(false)
  isOrganization Boolean       @default(false)
  fullAccessExpiresAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  examAttempts  ExamAttempt[]
  purchases     Purchase[]
  progress      UserProgress[]
  ownedCodes    PromoCode[]    @relation("OrgCodes")
  redeemedCodes PromoCode[]    @relation("RedeemedCodes")
  sessions      Session[]
  orders        Order[]
  orgProfile    OrganizationProfile?
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  lastUsedAt   DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizationProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  inn           String?
  kpp           String?
  ogrn          String?
  address       String?
  bankName      String?
  bankAccount   String?
  corrAccount   String?
  bik           String?
  phone         String?
  email         String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id             String   @id @default(cuid())
  code           String   @unique
  type           String   @default("FULL") // FULL or COURSE_ID
  courseId       String?
  organizationId String
  usedByUserId   String?  @unique
  maxUses        Int      @default(1)
  usedCount      Int      @default(0)
  createdAt      DateTime @default(now())
  expiresAt      DateTime?
  
  organization   User     @relation("OrgCodes", fields: [organizationId], references: [id])
  usedByUser     User?    @relation("RedeemedCodes", fields: [usedByUserId], references: [id])
}

model Course {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String?
  icon         String?
  examAttempts ExamAttempt[]
  purchases    Purchase[]
  questions    Question[]
  themes       Topic[]
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  expiresAt DateTime?
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Topic {
  id        String     @id @default(cuid())
  title     String
  order     Int        @default(0)
  courseId  String
  questions Question[]
  course    Course     @relation(fields: [courseId], references: [id])
}

model Question {
  id          String         @id @default(cuid())
  text        String
  explanation String?
  imageUrl    String?
  courseId    String
  topicId     String
  options     Option[]
  topic       Topic          @relation(fields: [topicId], references: [id])
  course      Course         @relation(fields: [courseId], references: [id])
  progress    UserProgress[]
}

model Option {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
}

model UserProgress {
  id              String   @id @default(cuid())
  userId          String
  questionId      String
  isCorrect       Boolean?
  lastAttemptedAt DateTime @default(now())
  question        Question @relation(fields: [questionId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, questionId])
}

model ExamAttempt {
  id         String    @id @default(cuid())
  userId     String
  courseId   String
  score      Int
  isPassed   Boolean
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  timeTaken  Int?
  details    String?
  course     Course    @relation(fields: [courseId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  userName        String
  userPhone       String
  address         String?
  courseIds       String   // JSON string of course IDs
  deliveryCost    Float    @default(0)
  discountPercent Int      @default(0)
  totalAmount     Float
  status          String   @default("NEW") // NEW, CONTACTED, THINKING, ADDRESS_FILLED, SENT, COMPLETED
  trackNumber     String?
  deliveryCompany String?  // POCHTA, DHL, CDEK
  isSentToDashboard Boolean @default(false)
  isPaid          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
